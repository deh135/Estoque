<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="450.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.debora.estoque.MenuController">
   <left>
      <VBox prefHeight="450.0" prefWidth="197.0" styleClass="menu" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnVizualisarEstoque" mnemonicParsing="false" onAction="#aoVisualizarEstoque" prefHeight="42.0" prefWidth="201.0" text="Visualizar Estoque" textFill="#f8f2f1">
               <styleClass>
                  <String fx:value="titulo" />
                  <String fx:value="botao-menu" />
                  <String fx:value="botao" />
               </styleClass>
            </Button>
            <Button fx:id="btnEntradaDeProduto" layoutX="20.0" layoutY="15.0" mnemonicParsing="false" onAction="#aoCadastrarProdutos" prefHeight="42.0" prefWidth="201.0" text="Entrada de Produtos" textFill="#f8f2f1">
               <styleClass>
                  <String fx:value="titulo" />
                  <String fx:value="botao-menu" />
                  <String fx:value="botao" />
               </styleClass>
            </Button>
            <Button fx:id="btnRelatorio" layoutX="20.0" layoutY="57.0" mnemonicParsing="false" onAction="#aoGerarRelatorio" prefHeight="42.0" prefWidth="201.0" text="Relatorio" textFill="#f8f2f1">
               <styleClass>
                  <String fx:value="titulo" />
                  <String fx:value="botao-menu" />
                  <String fx:value="botao" />
               </styleClass>
            </Button>
            <Button fx:id="btnSair" layoutX="20.0" layoutY="99.0" mnemonicParsing="false" onAction="#aoSair" prefHeight="42.0" prefWidth="201.0" text="Sair" textFill="#f8f2f1">
               <styleClass>
                  <String fx:value="titulo" />
                  <String fx:value="botao-menu" />
                  <String fx:value="botao" />
               </styleClass>
               <graphic>
                  <FontIcon iconColor="#330708" iconLiteral="mdi2e-exit-to-app" iconSize="30" />
               </graphic>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" styleClass="fundo" BorderPane.alignment="CENTER">
         <children>
            <Label text="Bem Vindo !" textFill="#330708">
               <font>
                  <Font name="Broadway" size="19.0" />
               </font>
            </Label>
         </children></VBox>
   </center>
</BorderPane>
