<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<BorderPane prefHeight="450.0" prefWidth="700.0" style="-fx-background-color: #f8f2f1;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.debora.estoque.EstoqueController">
   <center>
      <VBox prefHeight="113.0" prefWidth="700.0" BorderPane.alignment="CENTER">
         <children>
            <Label prefHeight="21.0" prefWidth="220.0" text="Produtos em Estoque" textFill="#330708">
               <font>
                  <Font name="Broadway" size="18.0" />
               </font>
            </Label>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <TextField prefHeight="31.0" prefWidth="294.0">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" style="-fx-background-color: #d9abff;" text="+Adicionar" textFill="#330708">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Bell MT" size="15.0" />
                     </font>
                  </Button>
                  <Button layoutX="197.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: #d9abff;" text="Editar" textFill="#330708">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Bell MT" size="15.0" />
                     </font>
                  </Button>
                  <Button layoutX="511.0" layoutY="27.0" mnemonicParsing="false" style="-fx-background-color: #d9abff;" text="Remover" textFill="#330708">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Bell MT" size="15.0" />
                     </font>
                  </Button>
                  <Button layoutX="521.0" layoutY="27.0" mnemonicParsing="false" style="-fx-background-color: #d9abff;" text="voltar" textFill="#330708" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="30.0" right="30.0" top="10.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <TableView prefHeight="339.0" prefWidth="700.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn prefWidth="122.0" text="ID" />
          <TableColumn prefWidth="128.0" text="Nome" />
            <TableColumn prefWidth="146.0" text="Categoria" />
            <TableColumn prefWidth="136.0" text="Quantidade" />
            <TableColumn prefWidth="107.0" text="Preco(R$)" />
        </columns>
         <BorderPane.margin>
            <Insets bottom="10.0" left="30.0" right="30.0" />
         </BorderPane.margin>
      </TableView>
   </bottom>
</BorderPane>
